# Copy this file to signing.properties and fill in your own values.
# This file should NOT be committed with real credentials.
# On Windows, you can bootstrap this file with: ./scripts/setup-release-signing.ps1
# On macOS/Linux, you can bootstrap this file with: ./scripts/setup-release-signing.sh

# Absolute path or path relative to repository root.
keystore.path=release.keystore

# Keystore password.
keystore.password=YOUR_KEYSTORE_PASSWORD

# Key alias inside the keystore.
key.alias=YOUR_KEY_ALIAS

# Password for the key alias.
key.password=YOUR_KEY_PASSWORD

# Startup gate release fingerprint is derived automatically from this keystore.
# You normally do not need to set startup.gate.releaseFingerprint separately
# when building a signed release artifact.
